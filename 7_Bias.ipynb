    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "df = pd.read_csv(\"student-mat.csv\", sep=\";\")\n",
    "\n",
    "group = df.groupby(\"sex\")[\"G3\"].mean()\n",
    "\n",
    "print(group)\n",
    "\n",
    "group.plot(kind=\"bar\")\n",
    "plt.title(\"Average Grade by Gender\")\n",
    "plt.xlabel(\"Gender\")\n",
    "plt.ylabel(\"Average G3\")\n",
    "plt.show()"
   ]
  }
 ],
